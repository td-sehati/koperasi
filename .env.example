NODE_ENV=development
PORT=3000

# Supabase Postgres (Session Pooler - IPv4 compatible)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=no-verify

# Optional direct connection (usually for local tools)
DATABASE_URL_DIRECT=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=no-verify

# Optional app settings
ADMIN_USERNAME=owner
ADMIN_PASSWORD=owner123
SUBSCRIPTION_FEE_LABEL=Rp 90.000 / 30 hari
SUBSCRIPTION_PAY_TO=Transfer ke rekening owner aplikasi
SUBSCRIPTION_CONFIRM_TO=Konfirmasi via WhatsApp ke owner aplikasi
